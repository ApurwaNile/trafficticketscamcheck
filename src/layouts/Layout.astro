---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'US Traffic Ticket Scam Checker | Verify Your Citation',
  description = 'Check if your traffic ticket or toll notice is real or a scam. Free instant verification tool to protect yourself from phishing scams.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="traffic ticket scam, toll notice scam, verify traffic citation, phishing scam checker, DMV scam" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://trafficticketscamcheck.com" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-canvas-soft text-ink">
    <slot />
  </body>
</html>
