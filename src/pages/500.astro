---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  error: unknown;
}

const { error } = Astro.props;
---

<Layout title="Something went wrong | ScamCheck" description="An unexpected error occurred.">
  <Nav />
  <main class="w-full flex flex-col">
    <section class="w-full py-16 md:py-24">
      <div class="max-w-[800px] mx-auto px-4 sm:px-6 text-center">
        <p class="text-body text-error mb-4">Error 500</p>
        <h1 class="text-display-md md:text-display-lg font-semibold text-ink mb-4">Something went wrong</h1>
        <p class="text-body text-mute mb-8">An unexpected error occurred. Please try again later.</p>
        <a href="/" class="inline-block px-6 py-3 bg-link text-white font-medium rounded-[var(--radius-md)] hover:opacity-90 transition-opacity">
          Go home
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
