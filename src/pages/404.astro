---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found | ScamCheck" description="The page you are looking for does not exist.">
  <Nav />
  <main class="w-full flex flex-col">
    <section class="w-full py-16 md:py-24">
      <div class="max-w-[800px] mx-auto px-4 sm:px-6 text-center">
        <p class="text-body text-mute mb-4">Error 404</p>
        <h1 class="text-display-md md:text-display-lg font-semibold text-ink mb-4">Page not found</h1>
        <p class="text-body text-mute mb-8">The page you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="inline-block px-6 py-3 bg-link text-white font-medium rounded-[var(--radius-md)] hover:opacity-90 transition-opacity">
          Go home
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
