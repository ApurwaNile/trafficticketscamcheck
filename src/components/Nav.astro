---
---

<nav class="sticky top-0 z-50 bg-canvas/80 backdrop-blur-lg border-b border-hairline">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-ink font-semibold text-[15px] shrink-0">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>ScamCheck</span>
    </a>
    
    <div class="hidden md:flex items-center gap-1">
      <a href="/quiz" class="px-3 py-1.5 text-body text-[14px] hover:text-ink transition-colors rounded-full hover:bg-canvas-soft-2">Check Now</a>
      <a href="/directory" class="px-3 py-1.5 text-body text-[14px] hover:text-ink transition-colors rounded-full hover:bg-canvas-soft-2">Gov Directory</a>
      <a href="/toll-alerts" class="px-3 py-1.5 text-body text-[14px] hover:text-ink transition-colors rounded-full hover:bg-canvas-soft-2">Toll Alerts</a>
      <a href="/report" class="px-3 py-1.5 text-body text-[14px] hover:text-ink transition-colors rounded-full hover:bg-canvas-soft-2">Report</a>
      <span class="w-px h-4 bg-hairline mx-1"></span>
      <a href="/about" class="px-3 py-1.5 text-body text-[14px] hover:text-ink transition-colors rounded-full hover:bg-canvas-soft-2">About</a>
      <a href="/contact" class="px-3 py-1.5 text-body text-[14px] hover:text-ink transition-colors rounded-full hover:bg-canvas-soft-2">Contact</a>
    </div>

    <div class="flex items-center gap-2">
      <a href="/quiz" class="hidden sm:inline-flex items-center px-4 py-1.5 bg-primary text-on-primary text-[14px] font-medium rounded-full hover:bg-ink/90 transition-colors">
        Verify Now
      </a>
      <button id="dark-mode-btn" class="p-2 rounded-lg hover:bg-canvas-soft-2 transition-colors text-body hover:text-ink" aria-label="Toggle dark mode">
        <svg class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-canvas-soft-2 transition-colors" aria-label="Toggle menu">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-hairline bg-canvas">
    <div class="px-4 py-3 space-y-1">
      <a href="/quiz" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">Check Now</a>
      <a href="/directory" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">Gov Directory</a>
      <a href="/toll-alerts" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">Toll Alerts</a>
      <a href="/report" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">Report</a>
      <div class="border-t border-hairline my-2"></div>
      <a href="/about" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">About</a>
      <a href="/contact" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">Contact</a>
      <a href="/privacy" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">Privacy Policy</a>
      <a href="/terms" class="block px-3 py-2 text-body text-[14px] hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-colors">Terms & Conditions</a>
      <a href="/quiz" class="block px-3 py-2 bg-primary text-on-primary text-[14px] font-medium rounded-full text-center mt-2">Verify Now</a>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const darkModeBtn = document.getElementById('dark-mode-btn');
  
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  darkModeBtn?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('dark-mode', document.documentElement.classList.contains('dark'));
  });

  // Close menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
