---
---

<section class="w-full relative overflow-hidden">
  <!-- Mesh gradient backdrop -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[800px] h-[600px] opacity-30">
      <div class="absolute inset-0 bg-gradient-to-br from-[#007cf0] via-[#7928ca] to-[#ff0080] rounded-full blur-3xl"></div>
      <div class="absolute inset-0 bg-gradient-to-tr from-[#00dfd8] via-[#ff0080] to-[#f9cb28] rounded-full blur-3xl opacity-60"></div>
    </div>
  </div>

  <div class="relative w-full max-w-[1400px] mx-auto px-4 sm:px-6 pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="text-center w-full max-w-[48rem] mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline rounded-full text-[12px] font-mono text-body mb-6">
        <span class="w-2 h-2 bg-success rounded-full animate-pulse"></span>
        Free instant verification
      </div>

      <!-- Headline -->
      <h1 class="text-[36px] md:text-[48px] font-semibold leading-[1] tracking-[-2.4px] text-ink mb-6">
        Is your traffic ticket real?
      </h1>

      <!-- Subheadline -->
      <p class="text-[18px] md:text-[20px] text-body leading-[28px] mb-8 max-w-[42rem] mx-auto">
        Verify if a traffic citation or toll notice is legitimate or a phishing scam. 
        Protect yourself and your community from fraud.
      </p>

      <!-- CTA Row -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/quiz" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-on-primary text-[16px] font-medium rounded-full hover:bg-ink/90 transition-all hover:scale-[1.02] active:scale-[0.98]">
          Check Your Ticket
          <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        <a href="/directory" class="inline-flex items-center justify-center px-6 py-3 bg-canvas text-ink text-[16px] font-medium rounded-full border border-hairline hover:bg-canvas-soft-2 transition-all">
          View Gov Directory
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-[13px] text-mute">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          No data collected
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Instant results
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          100% private
        </div>
      </div>
    </div>
  </div>
</section>
