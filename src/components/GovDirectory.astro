  { name: "Federal Trade Commission", url: "https://reportfraud.ftc.gov", description: "Report fraud and scams" },
  { name: "FBI Internet Crime Complaint Center", url: "https://www.ic3.gov", description: "Report cybercrime" },
  { name: "US Postal Inspection Service", url: "https://www.uspis.gov", description: "Report mail fraud" },
  { name: "National Highway Traffic Safety Admin", url: "https://www.nhtsa.gov", description: "Vehicle safety info" },
];
---

<section id="directory" class="py-16 md:py-24 bg-canvas-soft">
  <div class="w-full max-w-[1400px] mx-auto px-4 sm:px-6">
      <!-- Section header -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline rounded-full text-[12px] font-mono text-body mb-4">
          Safe .Gov Directory
        </div>
        <h2 class="text-[24px] md:text-[32px] font-semibold leading-[40px] tracking-[-1.28px] text-ink mb-4">
          Official government resources
        </h2>
        <p class="text-[16px] text-body leading-[24px] max-w-2xl mx-auto">
          Verify your ticket directly through official .gov websites. Never use links from suspicious messages.
        </p>
      </div>

      <!-- Federal resources -->
      <div class="mb-10">
        <h3 class="text-[14px] font-mono text-mute uppercase tracking-wider mb-4">Federal Resources</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {federalResources.map((resource) => (
            <a 
              href={resource.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="flex items-center justify-between p-4 bg-canvas border border-hairline rounded-lg hover:border-hairline-strong hover:shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a] transition-all group"
            >
              <div>
                <p class="text-[15px] font-medium text-ink group-hover:text-link transition-colors">{resource.name}</p>
                <p class="text-[13px] text-body mt-0.5">{resource.description}</p>
              </div>
              <svg class="w-4 h-4 text-mute group-hover:text-link transition-colors flex-shrink-0 ml-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- State directory -->
      <div>
        <h3 class="text-[14px] font-mono text-mute uppercase tracking-wider mb-4">State DMV / MVA Websites</h3>
        <div class="bg-canvas border border-hairline rounded-xl overflow-hidden shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <!-- Search/Filter -->
          <div class="p-4 border-b border-hairline">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-mute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input 
                type="text" 
                id="state-search" 
                placeholder="Search your state..." 
                class="w-full pl-10 pr-4 py-2.5 bg-canvas-soft border border-hairline rounded-lg text-[14px] text-ink placeholder:text-mute focus:outline-none focus:border-hairline-strong focus:ring-1 focus:ring-hairline-strong"
              />
            </div>
          </div>

          <!-- State list -->
          <div id="state-list" class="max-h-[400px] overflow-y-auto">
            {states.map((state) => (
              <a 
                href={state.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="state-item flex items-center justify-between px-4 py-3 border-b border-hairline last:border-b-0 hover:bg-canvas-soft-2 transition-colors group"
                data-state={state.name.toLowerCase()}
              >
                <div>
                  <p class="text-[14px] font-medium text-ink group-hover:text-link transition-colors">{state.name}</p>
                  <p class="text-[12px] text-body">{state.dmv}</p>
                </div>
                <svg class="w-4 h-4 text-mute group-hover:text-link transition-colors flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>

          <!-- Empty state -->
          <div id="state-empty" class="hidden p-8 text-center">
            <p class="text-[14px] text-body">No states found matching your search.</p>
          </div>
        </div>
      </div>

      <!-- Warning -->
      <div class="mt-6 p-4 bg-warning-soft border border-warning/20 rounded-lg">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-warning flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div>
            <p class="text-[14px] font-medium text-warning-deep mb-1">Important Reminder</p>
            <p class="text-[13px] text-body">
              Official DMV websites will <strong>never</strong> ask you to pay traffic tickets via text message links, QR codes, gift cards, or cryptocurrency. Always navigate directly to these sites—never click links from emails or texts.
            </p>
          </div>
        </div>
      </div>
  </div>
</section>

<script>
  const searchInput = document.getElementById('state-search') as HTMLInputElement;
  const stateList = document.getElementById('state-list');
  const stateEmpty = document.getElementById('state-empty');

  searchInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    const query = target.value.toLowerCase().trim();
    
    const items = stateList?.querySelectorAll('.state-item');
    let visibleCount = 0;

    items?.forEach((item) => {
      const stateName = item.getAttribute('data-state') || '';
      const matches = stateName.includes(query);
      (item as HTMLElement).style.display = matches ? 'flex' : 'none';
      if (matches) visibleCount++;
    });

    if (stateEmpty) {
      stateEmpty.classList.toggle('hidden', visibleCount > 0);
    }
  });
</script>
