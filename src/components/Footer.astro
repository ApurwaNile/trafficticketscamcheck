---
---

<footer class="py-12 md:py-16 bg-canvas border-t border-hairline">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 text-ink font-semibold text-[15px] mb-4">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          ScamCheck
        </a>
        <p class="text-[13px] text-body leading-[20px]">
          Free tool to verify traffic tickets and toll notices. Protect yourself and your community from phishing scams.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <p class="text-[12px] font-mono text-mute uppercase tracking-wider mb-4">Quick Links</p>
        <ul class="space-y-2">
          <li><a href="/quiz" class="text-[14px] text-body hover:text-ink transition-colors">Check Your Ticket</a></li>
          <li><a href="/directory" class="text-[14px] text-body hover:text-ink transition-colors">Gov Directory</a></li>
          <li><a href="/toll-alerts" class="text-[14px] text-body hover:text-ink transition-colors">Toll Alerts</a></li>
          <li><a href="/report" class="text-[14px] text-body hover:text-ink transition-colors">Report a Scam</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <p class="text-[12px] font-mono text-mute uppercase tracking-wider mb-4">Resources</p>
        <ul class="space-y-2">
          <li>
            <a href="https://reportfraud.ftc.gov" target="_blank" rel="noopener noreferrer" class="text-[14px] text-body hover:text-ink transition-colors inline-flex items-center gap-1">
              ReportFraud.ftc.gov
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </li>
          <li>
            <a href="https://consumer.ftc.gov/scams" target="_blank" rel="noopener noreferrer" class="text-[14px] text-body hover:text-ink transition-colors inline-flex items-center gap-1">
              FTC Scam Alerts
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </li>
          <li>
            <a href="https://www.ic3.gov" target="_blank" rel="noopener noreferrer" class="text-[14px] text-body hover:text-ink transition-colors inline-flex items-center gap-1">
              FBI IC3
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- About -->
      <div>
        <p class="text-[12px] font-mono text-mute uppercase tracking-wider mb-4">About</p>
        <ul class="space-y-2">
          <li><span class="text-[14px] text-body">100% free to use</span></li>
          <li><span class="text-[14px] text-body">No data collected</span></li>
          <li><span class="text-[14px] text-body">No account required</span></li>
          <li><span class="text-[14px] text-body">Static & fast</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-hairline flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-[13px] text-body">
        &copy; {new Date().getFullYear()} TrafficTicketScamCheck.com. All rights reserved.
      </p>
      <p class="text-[12px] text-mute">
        This tool provides educational information only. Always verify with official government sources.
      </p>
    </div>
  </div>
</footer>
