---
---

<section id="report" class="w-full py-16 md:py-24 bg-canvas-soft">
  <div class="w-full max-w-[1400px] mx-auto px-4 sm:px-6">
      <!-- Section header -->
      <div class="text-center mb-10 w-full max-w-[48rem] mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline rounded-full text-[12px] font-mono text-body mb-4">
          Report Action Plan
        </div>
        <h2 class="text-[24px] md:text-[32px] font-semibold leading-[40px] tracking-[-1.28px] text-ink mb-4">
          Take action against scams
        </h2>
        <p class="text-[16px] text-body leading-[24px] max-w-[42rem] mx-auto">
          Follow these steps to report scam messages and help protect others from fraud.
        </p>
      </div>

      <!-- Steps -->
      <div class="space-y-6">
        <!-- Step 1 -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center flex-shrink-0 text-[14px] font-semibold">
              1
            </div>
            <div class="flex-1">
              <h3 class="text-[18px] font-semibold text-ink mb-2">Forward scam texts to 7726</h3>
              <p class="text-[15px] text-body mb-4">
                Forward the scam text message to <strong class="text-ink">7726</strong> (which spells SPAM on your phone keypad). This reports the scammer to your carrier.
              </p>
              
              <div class="bg-canvas-soft border border-hairline rounded-lg p-4">
                <p class="text-[13px] font-medium text-ink mb-3">How to forward on iPhone:</p>
                <ol class="text-[13px] text-body space-y-1 list-decimal list-inside">
                  <li>Press and hold the scam text message</li>
                  <li>Tap "More" in the context menu</li>
                  <li>Tap the forward arrow (bottom right)</li>
                  <li>Type 7726 and send</li>
                </ol>
                
                <div class="mt-3 pt-3 border-t border-hairline">
                  <p class="text-[13px] font-medium text-ink mb-3">How to forward on Android:</p>
                  <ol class="text-[13px] text-body space-y-1 list-decimal list-inside">
                    <li>Long press the scam text message</li>
                    <li>Tap "Forward" or the forward icon</li>
                    <li>Type 7726 and send</li>
                  </ol>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center flex-shrink-0 text-[14px] font-semibold">
              2
            </div>
            <div class="flex-1">
              <h3 class="text-[18px] font-semibold text-ink mb-2">Report to the FTC</h3>
              <p class="text-[15px] text-body mb-4">
                File a report with the Federal Trade Commission at ReportFraud.ftc.gov. Your report helps them investigate and stop scammers.
              </p>
              
              <a 
                href="https://reportfraud.ftc.gov" 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center px-5 py-2.5 bg-primary text-on-primary text-[14px] font-medium rounded-full hover:bg-ink/90 transition-all"
              >
                Report at ReportFraud.ftc.gov
                <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center flex-shrink-0 text-[14px] font-semibold">
              3
            </div>
            <div class="flex-1">
              <h3 class="text-[18px] font-semibold text-ink mb-2">Report to your state Attorney General</h3>
              <p class="text-[15px] text-body mb-4">
                File a complaint with your state's Attorney General office for additional investigation and consumer protection.
              </p>
              
              <a 
                href="https://www.naag.org/our-work/attorney-general-background/" 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center px-5 py-2.5 bg-canvas text-ink text-[14px] font-medium rounded-full border border-hairline hover:bg-canvas-soft-2 transition-all"
              >
                Find Your State AG
                <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center flex-shrink-0 text-[14px] font-semibold">
              4
            </div>
            <div class="flex-1">
              <h3 class="text-[18px] font-semibold text-ink mb-2">Block and delete</h3>
              <p class="text-[15px] text-body mb-4">
                Block the sender and delete the scam message. Do not respond or click any links.
              </p>
              
              <div class="bg-canvas-soft border border-hairline rounded-lg p-4">
                <p class="text-[14px] text-body">
                  <strong class="text-ink">Remember:</strong> Never pay traffic tickets or tolls through links in text messages or emails. Always verify directly with official government websites or visit your local DMV office.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional resources -->
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a 
          href="https://consumer.ftc.gov/scams" 
          target="_blank" 
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 bg-canvas border border-hairline rounded-lg hover:border-hairline-strong hover:shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a] transition-all group"
        >
          <div class="w-10 h-10 bg-link-bg-soft rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <p class="text-[14px] font-medium text-ink group-hover:text-link transition-colors">FTC Scam Alerts</p>
            <p class="text-[12px] text-body">consumer.ftc.gov</p>
          </div>
        </a>

        <a 
          href="https://www.ic3.gov" 
          target="_blank" 
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 bg-canvas border border-hairline rounded-lg hover:border-hairline-strong hover:shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a] transition-all group"
        >
          <div class="w-10 h-10 bg-link-bg-soft rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <p class="text-[14px] font-medium text-ink group-hover:text-link transition-colors">FBI IC3</p>
            <p class="text-[12px] text-body">Report cybercrime</p>
          </div>
        </a>
      </div>
  </div>
</section>
