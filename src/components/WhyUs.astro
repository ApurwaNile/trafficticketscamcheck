---
---

<section class="w-full py-16 md:py-24 bg-canvas">
  <div class="w-full max-w-[1400px] mx-auto px-4 sm:px-6">
      <!-- Section header -->
      <div class="text-center mb-10 w-full max-w-[48rem] mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas-soft border border-hairline rounded-full text-[12px] font-mono text-body mb-4">
          Why ScamCheck
        </div>
        <h2 class="text-[24px] md:text-[32px] font-semibold leading-[40px] tracking-[-1.28px] text-ink mb-4">
          Better than general fraud reporting
        </h2>
        <p class="text-[16px] text-body leading-[24px] max-w-[42rem] mx-auto">
          Unlike general fraud report sites, we focus specifically on traffic ticket and toll scams with instant verification.
        </p>
      </div>

      <!-- Feature comparison -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="w-10 h-10 bg-link-bg-soft rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-[18px] font-semibold text-ink mb-2">Instant Results</h3>
          <p class="text-[14px] text-body leading-[20px]">
            Get immediate answers about your ticket. No waiting for investigations or report numbers.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="w-10 h-10 bg-link-bg-soft rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-[18px] font-semibold text-ink mb-2">Traffic Ticket Focus</h3>
          <p class="text-[14px] text-body leading-[20px]">
            Purpose-built for DMV and toll scams. Not a generic fraud form that covers all industries.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="w-10 h-10 bg-link-bg-soft rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-[18px] font-semibold text-ink mb-2">100% Private</h3>
          <p class="text-[14px] text-body leading-[20px]">
            All logic runs locally. No data leaves your browser. No account or personal info required.
          </p>
        </div>
      </div>

      <!-- Comparison table -->
      <div class="mt-12 bg-canvas border border-hairline rounded-xl overflow-hidden shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
        <div class="p-4 border-b border-hairline bg-canvas-soft">
          <h3 class="text-[14px] font-medium text-ink">Feature Comparison</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-hairline">
                <th class="text-left p-4 text-[13px] font-medium text-body">Feature</th>
                <th class="text-center p-4 text-[13px] font-medium text-link">ScamCheck</th>
                <th class="text-center p-4 text-[13px] font-medium text-body">ReportFraud.ftc.gov</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-hairline">
                <td class="p-4 text-[14px] text-ink">Instant scam verification</td>
                <td class="p-4 text-center"><span class="text-link">✓</span></td>
                <td class="p-4 text-center"><span class="text-mute">✗</span></td>
              </tr>
              <tr class="border-b border-hairline">
                <td class="p-4 text-[14px] text-ink">Traffic ticket specific</td>
                <td class="p-4 text-center"><span class="text-link">✓</span></td>
                <td class="p-4 text-center"><span class="text-mute">✗</span></td>
              </tr>
              <tr class="border-b border-hairline">
                <td class="p-4 text-[14px] text-ink">State DMV directory</td>
                <td class="p-4 text-center"><span class="text-link">✓</span></td>
                <td class="p-4 text-center"><span class="text-mute">✗</span></td>
              </tr>
              <tr class="border-b border-hairline">
                <td class="p-4 text-[14px] text-ink">Toll fraud alerts</td>
                <td class="p-4 text-center"><span class="text-link">✓</span></td>
                <td class="p-4 text-center"><span class="text-mute">✗</span></td>
              </tr>
              <tr class="border-b border-hairline">
                <td class="p-4 text-[14px] text-ink">No personal data required</td>
                <td class="p-4 text-center"><span class="text-link">✓</span></td>
                <td class="p-4 text-center"><span class="text-mute">✗</span></td>
              </tr>
              <tr>
                <td class="p-4 text-[14px] text-ink">Reports to law enforcement</td>
                <td class="p-4 text-center"><span class="text-mute">✗</span></td>
                <td class="p-4 text-center"><span class="text-link">✓</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
  </div>
</section>
