---
---

<section id="alerts" class="py-16 md:py-24 bg-canvas">
  <div class="w-full max-w-[1400px] mx-auto px-4 sm:px-6">
      <!-- Section header -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-error-soft border border-error/20 rounded-full text-[12px] font-mono text-error mb-4">
          Toll Fraud Alerts
        </div>
        <h2 class="text-[24px] md:text-[32px] font-semibold leading-[40px] tracking-[-1.28px] text-ink mb-4">
          Fake SunPass & E-ZPass scams
        </h2>
        <p class="text-[16px] text-body leading-[24px] max-w-2xl mx-auto">
          Scammers are sending fake toll violation texts to steal your money and personal information.
        </p>
      </div>

      <!-- Alert cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- SunPass alert -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-error-soft rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-error" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <div>
              <h3 class="text-[18px] font-semibold text-ink">SunPass Scam Alert</h3>
              <p class="text-[12px] font-mono text-mute">Florida Toll System</p>
            </div>
          </div>
          
          <div class="space-y-3 mb-4">
            <div class="flex items-start gap-2">
              <span class="text-error mt-0.5">•</span>
              <p class="text-[14px] text-body">Fake texts claiming unpaid tolls with links to "pay now"</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-error mt-0.5">•</span>
              <p class="text-[14px] text-body">Messages threaten license suspension or additional fees</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-error mt-0.5">•</span>
              <p class="text-[14px] text-body">Links lead to phishing sites that steal payment info</p>
            </div>
          </div>

          <div class="p-3 bg-canvas-soft rounded-lg">
            <p class="text-[13px] text-body">
              <strong class="text-ink">Official SunPass:</strong> sunpass.com | Never pay via text links
            </p>
          </div>
        </div>

        <!-- E-ZPass alert -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-error-soft rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-error" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <div>
              <h3 class="text-[18px] font-semibold text-ink">E-ZPass Scam Alert</h3>
              <p class="text-[12px] font-mono text-mute">Multi-State Toll System</p>
            </div>
          </div>
          
          <div class="space-y-3 mb-4">
            <div class="flex items-start gap-2">
              <span class="text-error mt-0.5">•</span>
              <p class="text-[14px] text-body">Robocalls and texts about "unpaid toll charges"</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-error mt-0.5">•</span>
              <p class="text-[14px] text-body">Links to fake payment portals that look official</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-error mt-0.5">•</span>
              <p class="text-[14px] text-body">Requests for credit card or bank information via text</p>
            </div>
          </div>

          <div class="p-3 bg-canvas-soft rounded-lg">
            <p class="text-[13px] text-body">
              <strong class="text-ink">Official E-ZPass:</strong> ezpass.com | Never pay via text links
            </p>
          </div>
        </div>
      </div>

      <!-- How to identify -->
      <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-[0px_2px_2px_#0000000a,0px_8px_8px_-8px_#0000000a]">
        <h3 class="text-[18px] font-semibold text-ink mb-4">How to identify toll scams</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <p class="text-[14px] font-medium text-error mb-3 flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 18L18 6M6 6l12 12" />
              </svg>
              Red Flags
            </p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-error mt-0.5">•</span>
                Unsolicited text about unpaid tolls
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-error mt-0.5">•</span>
                Links to pay immediately
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-error mt-0.5">•</span>
                Threats of fines or license suspension
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-error mt-0.5">•</span>
                Requests for personal or payment info
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-error mt-0.5">•</span>
                Non-.gov website addresses
              </li>
            </ul>
          </div>
          
          <div>
            <p class="text-[14px] font-medium text-success mb-3 flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 13l4 4L19 7" />
              </svg>
              What Legitimate Notices Look Like
            </p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-success mt-0.5">•</span>
                Sent via official mail
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-success mt-0.5">•</span>
                Include your plate number
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-success mt-0.5">•</span>
                Reference specific violation details
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-success mt-0.5">•</span>
                Provide official contact numbers
              </li>
              <li class="flex items-start gap-2 text-[14px] text-body">
                <span class="text-success mt-0.5">•</span>
                Allow in-person payment options
              </li>
            </ul>
          </div>
        </div>
      </div>
  </div>
</section>
